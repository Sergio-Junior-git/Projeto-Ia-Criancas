FLASK_ENV=development
SECRET_KEY=troque-esta-chave-em-producao
# SQLite local:
# DATABASE_URL=sqlite:///hospital_estudos.db

# MySQL local, troque usuario, senha e nome_do_banco pelo banco que voce criar:
DATABASE_URL=mysql+pymysql://localhost:2431@127.0.0.1:3306/db_projetoiacrianca?charset=utf8mb4
SESSION_COOKIE_SECURE=false

# IA real gratis/rapida para apresentacao, via Groq:
# 1. Crie uma chave em https://console.groq.com/keys
# 2. Troque AI_PROVIDER para groq
AI_PROVIDER=local
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
